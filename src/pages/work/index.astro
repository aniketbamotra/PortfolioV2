---
// Work page — all projects, impact-ordered.
// Also accessible as a standalone route at /work for direct linking.
// Primary navigation is through the SPA shell in pages/index.astro.
import Nav from '../../components/Nav.astro';
import WorkEntry from '../../components/WorkEntry.astro';
import WorkEntrySmall from '../../components/WorkEntrySmall.astro';
import { ALL_PROJECTS } from '../../data/projects.js';
import '../../styles/global.css';
import '../../styles/work.css';
import '../../styles/nav.css';

const majorProjects = ALL_PROJECTS.filter(p => p.hasCaseStudy);
const minorProjects = ALL_PROJECTS.filter(p => !p.hasCaseStudy);
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Work — Aniket Bamotra</title>
  <meta name="description" content="Selected work by Aniket Bamotra — enterprise systems, creative builds, open experiments." />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
</head>
<body>
  <div id="curtain"></div>
  <Nav />

  <div id="work" class="view active">
    <div class="work-header">
      <h1 class="work-header-title">Selected<br/>Work</h1>
      <div class="work-header-right">
        <p class="work-header-desc">
          A selection of enterprise systems, creative builds, and open experiments.
          Each project is owned end-to-end — strategy through production.
        </p>
        <span class="work-header-meta">{ALL_PROJECTS.length} projects · 2022 – Ongoing</span>
      </div>
    </div>

    <div class="work-entries">
      {majorProjects.map((project, i) => (
        <WorkEntry project={project} index={i + 1} />
      ))}
    </div>

    <div class="work-section-divider">
      <span class="work-section-label">More work</span>
    </div>

    <div class="work-entries">
      {minorProjects.map((project, i) => (
        <WorkEntrySmall project={project} index={majorProjects.length + i + 1} />
      ))}
    </div>

    <footer class="work-footer">
      <span class="work-footer-text">Aniket Bamotra · {new Date().getFullYear()}</span>
      <span class="work-footer-text">More available on request</span>
    </footer>
  </div>
</body>
</html>
