{
  "_comment": "Snapshot of hardcoded scene defaults — not loaded at runtime. Values mirror src/scripts/* as of 2026-07-01. Tune in code or use dev GUI (?lights); this file is the canonical reference for handoff and future migration.",

  "meta": {
    "version": 1,
    "description": "Read-only inventory of Three.js homepage scene configuration",
    "skyMode": "dome",
    "modules": {
      "environment": false,
      "cloudLayer": false,
      "skyDome": true,
      "reflectiveFloor": true,
      "mistFront": true,
      "projector": true,
      "sceneGui": "dev or ?lights URL flag only"
    }
